<UserControl x:Class="vrchat_osc.About"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:vrchat_osc"
             mc:Ignorable="d"
             Foreground="{StaticResource PrimaryTextBrush}" Background="Transparent">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="2*"/>
            <RowDefinition Height="5*"/>
        </Grid.RowDefinitions>
        <Grid Grid.Row="0" x:Name="Title">
            <TextBlock Text="OSC VRCHAT" FontSize="32" HorizontalAlignment="Center" VerticalAlignment="Bottom"/>
        </Grid>
        <Grid x:Name="Body" Grid.Row="1">
            <Grid.RowDefinitions>
                <RowDefinition/>
                <RowDefinition/>
            </Grid.RowDefinitions>

            <StackPanel>
                <TextBlock TextAlignment="Center" Text="SAMPLE TEXT" 
                           FontSize="12" Margin="10,15,10,0" HorizontalAlignment="left" VerticalAlignment="Center" TextWrapping="Wrap"/>
                <TextBlock  TextAlignment="Center"  Text="SAMPLE TEXT" 
                            FontSize="12" Margin="10,5,10,0" HorizontalAlignment="Left" VerticalAlignment="Center" TextWrapping="Wrap"/>
            </StackPanel>
        </Grid>
    </Grid>
</UserControl>
