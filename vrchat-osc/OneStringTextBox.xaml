<UserControl x:Class="vrchat_osc.OneStringTextBox"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:vrchat_osc"
             mc:Ignorable="d"
             d:DesignHeight="25" d:DesignWidth="300" Background="Transparent">
    <Grid>

        <Grid >
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="35"/>
                <ColumnDefinition/>
            </Grid.ColumnDefinitions>
            
            <TextBlock x:Name="Counter" Text="1" Grid.Column="0"
                       Height="35" 
                       FontSize="14" 
                       VerticalAlignment="Center" 
                       HorizontalAlignment="Center" 
                       TextAlignment="Center" 
                       Margin="5" 
                       Width="35"/>
            
            <TextBox x:Name="InputBox" Style="{StaticResource VrChatTextBoxStyle}" Grid.Column="1"
                     Foreground="{StaticResource PrimaryTextBrush}"
                     FontFamily="Consolas"
                     HorizontalContentAlignment="Center"
                     VerticalContentAlignment="Center"
                     FontSize="24"
                     Padding="4"
                     Margin="5,5,5,5"
                     BorderBrush="Gray"
                     BorderThickness="1"/>
        </Grid>

    </Grid>
</UserControl>
